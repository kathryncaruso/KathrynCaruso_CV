% Shorthand
\newcommand{\github}[1]{\href{https://github.com/#1/}{github.com/#1}}
\newcommand{\email}[1]{\href{mailto:#1}{#1}}
\newcommand{\website}[1]{\href{https://#1/}{#1}}
\newcommand{\linkedin}[1]{\href{https://www.linkedin.com/in/#1/}{#1}}

% Dummy environment
\newenvironment*{dummyenv}{}{}

% Inline heading
\newcommand{\headingname}[1]{%
    \begin{minipage}[t]{.99\textwidth}
    \vspace*{\fill}
    \Huge \textcolor{color-title}{#1}
    \end{minipage}%
}

\newcommand{\headinginfo}[2]{
    \begin{minipage}[t]{.60\textwidth}
    \begin{flushleft}
    {#1}
    \end{flushleft}
    \end{minipage}
    \begin{minipage}[t]{.39\textwidth}
    \begin{flushright}
    {#2}
    \end{flushright}
    \end{minipage}
}

\newcommand{\headinginline}[2]{
    \begin{minipage}[t]{0.60\textwidth}
    \vspace*{\fill}
    \Huge \textcolor{color-title}{#1}
    \end{minipage}
    \begin{minipage}[t]{0.35\textwidth}
    \begin{flushright}
    #2
    \end{flushright}
    \end{minipage}
}

% Two-columns
\newcommand{\sidebyside}[2]{
    \noindent
    \begin{minipage}[t]{0.48\textwidth} \flushleft #1 \end{minipage}
    \hfill
    \begin{minipage}[t]{0.48\textwidth} \flushleft #2 \end{minipage}
}
