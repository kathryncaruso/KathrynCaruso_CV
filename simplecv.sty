% Section titles
\titleformat{\section}
  {\scshape\raggedright\Large\color{color-title}} % Format for the section title
  {} % Label (blank for sections)
  {0em} % Horizontal separation between label and title (0em means no space)
  {} % Code before the section title (no space before the title)
  [\titlerule\vspace{0.5ex}] % Code after the section title (horizontal rule and space)

\titlespacing{\section}
  {0pt} % Left spacing (0pt means no additional space)
  {3ex plus 0.5ex minus 0.2ex} % Space before the section title
  {0.5ex plus 0.2ex minus 0.2ex} % Space after the section title

% Footer
\fancyfoot[L]{\monthyeardate\today}
\fancyfoot[R]{\thepage}

% Lists
\newcommand{\outerlist}[1]{
    \begin{itemize}[leftmargin=1pt] #1 \end{itemize}}
\newcommand{\denseouterlist}[1]{
    \begin{itemize}[leftmargin=*,itemsep=0pt] #1 \end{itemize}}
\newcommand{\compactouterlist}[1]{
    \begin{itemize}[leftmargin=*,itemsep=0pt,parsep=1pt] #1 \end{itemize}}
\newcommand{\innerlist}[1]{
    \begin{itemize}[topsep=0pt] #1 \end{itemize}}
\newcommand{\orderedouterlist}[1]{
    \begin{enumerate}[leftmargin=*] #1 \end{enumerate}}
\newcommand{\bulleteddouterlist}[1]{
    \begin{itemize}[leftmargin=*] #1 \end{itemize}}

% List items
\newcommand{\entry}[1]{\item\small{#1}}
\newcommand{\entryextra}[1]{\textcolor{color-detail}{\entry{#1}}}
\newcommand{\entrylabeled}[2][]{\item[#1]\small{#2}}

\newcommand{\entrymid}[4][]{
    \item[#1] \small{#2} \hfill \small{#3}
    \vspace{-\smallskipamount} \item[]\small{\textit{#4}}}

\newcommand{\entrybig}[5][]{\item[#1]
    \begin{tabular*}{0.99\textwidth}{l@{\extracolsep{\fill}}r}
    #2 & #3 \\ 
    {\small#4} & {\small #5} \\ 
    \end{tabular*}}

\newcommand{\entrymiddle}[4][]{%
    \item[#1] \small{#2} % First entry on its own line
    \item[] % Creates a new line
    \small{#3} \hfill \small{#4} % Second and third entries, separated by \hfill
    \vspace{0.5em}
}

\newcommand{\entrybigwrap}[3][]{\item[#1]
    \centering
    \begin{tabular*}{0.95\textwidth}
    {l@{\extracolsep{\fill}}r}
    \multicolumn{2}{@{}p{0.97\textwidth}@{}}{#2} \\
    \multicolumn{2}{@{}p{0.97\textwidth}@{}}{#3} \\
    \end{tabular*}
}

% Fill year
\newcommand{\fillyear}[1]{\phantom{#1}}

% Make author name bold: https://tex.stackexchange.com/a/327046
\newcommand*{\boldname}[3]{%
  \def\lastname{#1}%
  \def\firstname{#2}%
  \def\firstinit{#3}}
\boldname{}{}{}

\renewcommand{\mkbibnamegiven}[1]{%
  \ifboolexpr{ ( test {\ifdefequal{\firstname}{\namepartgiven}} or test {\ifdefequal{\firstinit}{\namepartgiven}} ) and test {\ifdefequal{\lastname}{\namepartfamily}} }
  {\mkbibbold{#1}}{#1}%
}

\renewcommand{\mkbibnamefamily}[1]{%
  \ifboolexpr{ ( test {\ifdefequal{\firstname}{\namepartgiven}} or test {\ifdefequal{\firstinit}{\namepartgiven}} ) and test {\ifdefequal{\lastname}{\namepartfamily}} }
  {\mkbibbold{#1}}{#1}%
}

% Add okina
\DeclareRobustCommand{\okina}{%
  \raisebox{\dimexpr\fontcharht\font`A-\height}{%
    \scalebox{0.8}{`}%
  }%
}

% Thick line
\makeatletter
\def\thickhline{%
  \noalign{\ifnum0=`}\fi\hrule \@height \thickarrayrulewidth \futurelet
   \reserved@a\@xthickhline}
\def\@xthickhline{\ifx\reserved@a\thickhline
               \vskip\doublerulesep
               \vskip-\thickarrayrulewidth
             \fi
      \ifnum0=`{\fi}}
\makeatother